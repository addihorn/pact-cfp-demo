{
  "name": "todo-web",
  "private": true,
  "version": "0.2.0",
  "type": "commonjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5175",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "test": "vitest",
    "lint": "eslint src --ext ts,tsx",
    "playwright:install": "playwright install chromium --with-deps",
    "e2etest": "playwright test",
    "pact:publish": "dotenv -- cross-var pact-broker publish --validate --consumer-app-version $npm_package_version ./pacts/ --branch ${VERSION_BRANCH}",
    "pact:deploy-check": "dotenv -- cross-var pact-broker can-i-deploy --pacticipant ToDoService-Frontend -e $npm_package_version"
  },
  "dependencies": {
    
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@pact-foundation/pact-cli": "^18.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^4.1.4",
    "dotenv-cli": "^11.0.0",
    "cross-var": "^1.1.0"
  }
}