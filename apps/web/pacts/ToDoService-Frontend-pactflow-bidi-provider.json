{
  "consumer": {
    "name": "ToDoService-Frontend"
  },
  "interactions": [
    {
      "comments": {
        "testname": "reading the todo list generated a valid list in the ui"
      },
      "description": "a request to read all todos",
      "pending": false,
      "providerStates": [
        {
          "name": "at least three todos are in the database"
        }
      ],
      "request": {
        "headers": {
          "accept": [
            "*/*"
          ],
          "accept-language": [
            "en-US"
          ],
          "content-type": [
            "application/json"
          ],
          "origin": [
            "http://localhost:5173"
          ],
          "referer": [
            "http://localhost:5173/"
          ],
          "sec-ch-ua": [
            "\"HeadlessChrome\";v=\"147\", \"Not.A/Brand\";v=\"8\", \"Chromium\";v=\"147\""
          ],
          "sec-ch-ua-mobile": [
            "?0"
          ],
          "sec-ch-ua-platform": [
            "\"Windows\""
          ],
          "user-agent": [
            "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.7727.15 Safari/537.36"
          ]
        },
        "method": "GET",
        "path": "/api/v1/todos"
      },
      "response": {
        "body": {
          "content": {
            "data": [
              {
                "completed": false,
                "createdAt": "2026-07-21T18:17:43Z",
                "description": "This a new description of a todo",
                "id": 101,
                "title": "New ToDo",
                "updatedAt": "2026-07-22T00:17:43Z"
              },
              {
                "completed": false,
                "createdAt": "2026-07-21T18:17:43Z",
                "description": "This a new description of a todo",
                "id": 101,
                "title": "New ToDo",
                "updatedAt": "2026-07-22T00:17:43Z"
              },
              {
                "completed": false,
                "createdAt": "2026-07-21T18:17:43Z",
                "description": "This a new description of a todo",
                "id": 101,
                "title": "New ToDo",
                "updatedAt": "2026-07-22T00:17:43Z"
              }
            ]
          },
          "contentType": "application/json",
          "encoded": false
        },
        "generators": {
          "body": {
            "$.data[*].id": {
              "max": 10,
              "min": 0,
              "type": "RandomInt"
            }
          }
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 3
                }
              ]
            },
            "$.data[*].completed": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                },
                {
                  "match": "type"
                },
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                },
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                },
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.data[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                },
                {
                  "match": "type"
                },
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                },
                {
                  "match": "integer"
                },
                {
                  "match": "integer"
                }
              ]
            },
            "$.data[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                },
                {
                  "match": "type"
                },
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].updatedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                },
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                },
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "pactflow-bidi-provider"
  }
}